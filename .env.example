# Runtime
NODE_ENV=development

# Admin app base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (admin-only tenant/app settings)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_DOMAIN=
NEXT_PUBLIC_CLERK_IS_SATELLITE=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/unauthorized
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
ADMIN_INVITE_REDIRECT_URL=https://admin.loanpro.tech/sign-in
ADMIN_INIT_SECRET=

# Database
MONGODB_URI=
MONGODB_DB_NAME=AdminDB
MONGODB_SUPPORT_DB_NAME=

# Email and mailbox integrations
BREVO_API_KEY=
ADMIN_FROM_EMAIL=
ADMIN_MAILBOX_IMAP_USER=
ADMIN_MAILBOX_IMAP_PASSWORD=
ADMIN_MAILBOX_IMAP_HOST=imap.gmail.com
ADMIN_MAILBOX_IMAP_PORT=993

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloud Run (Android photo capture backend)
CLOUD_RUN_BASE_URL=
CLOUD_RUN_API_TOKEN=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Example for local .env:
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
# Keep the surrounding double quotes and replace every actual newline in the JSON private key with literal \n characters.

# Operational limits (optional but recommended for usage alerts)
ADMIN_LIMIT_GA_MONTHLY_EVENTS=
ADMIN_LIMIT_RAZORPAY_MONTHLY_TXNS=
ADMIN_LIMIT_BREVO_MONTHLY_EMAILS=
ADMIN_LIMIT_SUPPORT_OPEN_TICKETS=
ADMIN_LIMIT_CONTACT_OPEN_REQUESTS=
ADMIN_NOTIFICATION_RETENTION_DAYS=14

# Optional observability
LOG_LEVEL=info

# Optional one-time bootstrap for first super admin
ADMIN_BOOTSTRAP_CLERK_USER_ID=
ADMIN_BOOTSTRAP_EMAIL=

# Local API testing only (never set in production)
ADMIN_DEV_BYPASS_KEY=
